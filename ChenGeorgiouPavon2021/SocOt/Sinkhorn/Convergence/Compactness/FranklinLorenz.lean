/-
# Franklin--Lorenz finite matrix-scaling contraction seams

This file owns the paper-level Birkhoff--Hopf / Franklin--Lorenz Section 3 contraction input needed
by the finite Sinkhorn compactness proof.  It is intentionally separate from `ProjectiveLag.lean` so
future agents can work on the contraction port without touching the downstream compactness assembly.
-/

import ForMathlib.Analysis.ExpLogBounds
import ForMathlib.LinearAlgebra.Matrix.BirkhoffHopf
import ChenGeorgiouPavon2021.SocOt.Sinkhorn.Convergence.Compactness.MatrixBridge

set_option autoImplicit false

open MeasureTheory ProbabilityTheory
open scoped ENNReal BigOperators

namespace ChenGeorgiouPavon2021

/-- Two-sequence finite Franklin--Lorenz/Sinkhorn scaling orbit.

This is the mathlib-style abstraction behind the four-phase iterate system: `a` is the left
multiplicative scaling sequence and `b` is the right multiplicative scaling sequence.  The fields say
that the next left scaling normalizes rows to `p`, and the next right scaling normalizes columns to
`q`. -/
structure IsFiniteFranklinLorenzScalingOrbit {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù) : Prop where
  left_pos : ‚àÄ k i, 0 < a k i
  right_pos : ‚àÄ k j, 0 < b k j
  row_update : ‚àÄ k i, a (k + 1) i * (‚àë j, G i j * b k j) = p i
  column_update : ‚àÄ k j, b (k + 1) j * (‚àë i, G i j * a k i) = q j

/-- Shared box-bounds hypothesis for the two scaling sequences in the Franklin--Lorenz
two-sequence orbit. -/
def FranklinLorenzScalingBoxBounds {Œπ : Type*}
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù) : Prop :=
  ‚àÉ Œµ B : ‚Ñù, 0 < Œµ ‚àß 0 < B ‚àß
    (‚àÄ n i, Œµ ‚â§ a n i ‚àß a n i ‚â§ B) ‚àß
    (‚àÄ n j, Œµ ‚â§ b n j ‚àß b n j ‚â§ B)

/-- The four-phase Sinkhorn box bounds imply the two-sequence Franklin--Lorenz box bounds for
`(œÜhat0Iter, œÜ1Iter)`. -/
theorem franklinLorenzScalingBoxBounds_of_sinkhornPhaseBoxBounds {Œπ : Type*}
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hbounds : SinkhornPhaseBoxBounds œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter) :
    FranklinLorenzScalingBoxBounds œÜhat0Iter œÜ1Iter := by
  rcases hbounds with ‚ü®Œµ, B, hŒµ, hB, _hœÜ0, hœÜhat0, hœÜ1, _hœÜhat1‚ü©
  exact ‚ü®Œµ, B, hŒµ, hB, hœÜhat0, hœÜ1‚ü©

/-- The four-phase Sinkhorn iterate package induces the two-sequence Franklin--Lorenz scaling orbit
for the left hatted scaling `œÜhat0Iter` and right scaling `œÜ1Iter`. -/
theorem sinkhorn_isFiniteFranklinLorenzScalingOrbit {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hiter : IsFiniteSinkhornIterateSystem p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter) :
    IsFiniteFranklinLorenzScalingOrbit p q G œÜhat0Iter œÜ1Iter := by
  refine ‚ü®hiter.œÜhat0_pos, hiter.œÜ1_pos, ?_, ?_‚ü©
  ¬∑ intro k i
    rw [‚Üê hiter.forward k i]
    exact hiter.normalize_left k i
  ¬∑ intro k j
    rw [‚Üê hiter.backward k j]
    exact hiter.normalize_right k j

/-- Current column marginal for a two-sequence Franklin--Lorenz scaling orbit.

For left/right scalings `a k`, `b k`, this is the column-sum vector of the scaled matrix
`diag(a k) * G * diag(b k)`. -/
noncomputable def franklinLorenzCurrentColumnMarginal {Œπ : Type*} [Fintype Œπ]
    (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù) (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù) (k : ‚Ñï) : Œπ ‚Üí ‚Ñù :=
  fun j => (‚àë i, G i j * a k i) * b k j

/-- Current column marginal generated by a right phase and a hatted-right denominator.

By `sinkhorn_rowNormalizedMatrix_column_sum`, this is the column-sum vector of the preceding
row-normalized matrix.  The right Sinkhorn update divides the target marginal `q` by this current
column marginal, so this vector is the natural Franklin--Lorenz column-error object. -/
abbrev sinkhornCurrentColumnMarginal {Œπ : Type*}
    (œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù) (k : ‚Ñï) : Œπ ‚Üí ‚Ñù :=
  fun j => œÜhat1Iter k j * œÜ1Iter k j

/-- The Sinkhorn current column marginal is the current column marginal of the two-sequence
Franklin--Lorenz scaling orbit `(œÜhat0Iter, œÜ1Iter)`. -/
theorem sinkhorn_currentColumnMarginal_eq_franklinLorenzCurrentColumnMarginal
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hiter : IsFiniteSinkhornIterateSystem p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter)
    (k : ‚Ñï) :
    sinkhornCurrentColumnMarginal œÜ1Iter œÜhat1Iter k =
      franklinLorenzCurrentColumnMarginal G œÜhat0Iter œÜ1Iter k := by
  funext j
  unfold sinkhornCurrentColumnMarginal franklinLorenzCurrentColumnMarginal
  rw [‚Üê hiter.backward k j]

/-- The current column marginal of a positive Franklin--Lorenz orbit is strictly positive. -/
theorem franklinLorenzCurrentColumnMarginal_pos {Œπ : Type*} [Fintype Œπ]
    (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù) (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (ha_pos : ‚àÄ k i, 0 < a k i)
    (hb_pos : ‚àÄ k j, 0 < b k j)
    (k : ‚Ñï) (j : Œπ) :
    0 < franklinLorenzCurrentColumnMarginal G a b k j := by
  classical
  unfold franklinLorenzCurrentColumnMarginal
  apply mul_pos
  ¬∑ apply Finset.sum_pos
    ¬∑ intro i _hi
      exact mul_pos (hG i j) (ha_pos k i)
    ¬∑ exact ‚ü®j, Finset.mem_univ j‚ü©
  ¬∑ exact hb_pos k j

/-- The target column marginal `q` is strictly positive along a positive Franklin--Lorenz orbit. -/
theorem franklinLorenz_targetColumn_pos {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (horbit : IsFiniteFranklinLorenzScalingOrbit p q G a b)
    (k : ‚Ñï) (j : Œπ) :
    0 < q j := by
  classical
  rw [‚Üê horbit.column_update k j]
  apply mul_pos
  ¬∑ exact horbit.right_pos (k + 1) j
  ¬∑ apply Finset.sum_pos
    ¬∑ intro i _hi
      exact mul_pos (hG i j) (horbit.left_pos k i)
    ¬∑ exact ‚ü®j, Finset.mem_univ j‚ü©

/-!
## Hard-core theorem ledger for the right `œÜ1` / column-correction path

The expanded Franklin--Lorenz notes make an important correction to the theorem shape: Hilbert's
projective metric controls **pairwise logarithmic oscillation** of the correction vector
`q / c_k`, not directly the pointwise quantity `|log (q_j / c_{k,j})|` relative to `1`.
Consequently the right-side proof should no longer pass through pointwise log-to-one error.

The remaining hard pieces for the right side are now:

1. `ForMathlib.Matrix.positive_kernel_strict_birkhoff_contraction_coefficient` in
   `BirkhoffHopf.lean`: the paper-agnostic positive finite-kernel Birkhoff coefficient bundled
   with its Hilbert-projective contraction proof.
2. `hard_core_franklinLorenz_right_column_pairwise_log_correction_geometric_bound`: the
   Franklin--Lorenz Lemma 2/Theorem 4 step giving geometric decay of the Hilbert/projective spread
   of the column correction vector `q / c_k`.
3. `hard_core_franklinLorenz_pairwise_correction_bound_of_pairwise_log_bound_and_ratio_box`: the
   finite real-analysis bridge from a pairwise log-ratio bound plus the already-proved finite box
   bound to the concrete pairwise difference bound needed by `finitePairwiseRatioSpread`.
4. `hard_core_sinkhorn_phihat0_forward_ratio_spread_geometric_bound`: the still-unmirrored left-side
   row-correction theorem.

The non-`hard_core_*` theorems below are wrappers used by downstream code; they should stay stable
while agents attack the hard-core theorem statements independently.
-/

/-- Hard core 2: Franklin--Lorenz / Birkhoff--Hopf projective log-oscillation decay for the right
column correction.

This is the theorem shape directly suggested by the expanded Franklin--Lorenz Section 3 notes:
Lemma 2 gives geometric decay of `d(c^(k), q)`, equivalently geometric decay of the Hilbert spread
of the correction vector `q / c^(k)`.  In coordinates, this controls the pairwise log-ratio

`|log ((q i / c_k i) / (q j / c_k j))|`.

This avoids the stronger and generally unjustified pointwise-to-one claim
`|log (q j / c_k j)| ‚â§ C Œ≥^k`.

‚öÝÔ∏è The proof needs the Birkhoff--Hopf coefficient for **both `G` and `G·µÄ`**.  The orbit alternates
`a (k+1) = p / (G ¬∑ b k)` and `b (k+1) = q / (G·µÄ ¬∑ a k)`, so the contraction recursion uses each
kernel on alternate half-steps.  Deriving `G·µÄ`'s coefficient from `G`'s would require knowing `Œ≥` is
the *sharp* Birkhoff constant ‚Äî a strictly harder theorem.  Callers get both from
`ForMathlib.Matrix.positive_kernel_strict_birkhoff_contraction_coefficient_transpose`, whose explicit
coefficient is transpose-invariant.

**Proof.** Write `S k = G·µÄ ¬∑ a k` and `T k = G ¬∑ b k`, so `b (k+1) = q / S k` and `a (k+1) = p / T k`.
Since `x ‚Ü¶ c / x` is a projective isometry, with `Œ± k = d(a (k+1), a k)` and `Œ≤ k = d(b (k+1), b k)`,

`Œ≤ (k+1) = d(G·µÄ¬∑a (k+1), G·µÄ¬∑a k) ‚â§ Œ≥ ¬∑ Œ± k`  and  `Œ± (k+1) = d(G¬∑b (k+1), G¬∑b k) ‚â§ Œ≥ ¬∑ Œ≤ k`.

So `M k = max (Œ± k) (Œ≤ k)` satisfies `M (k+1) ‚â§ Œ≥ ¬∑ M k`, hence `M k ‚â§ Œ≥^k ¬∑ M 0` ‚Äî no parity
argument is needed.  The target quantity is `|log ((b (k+1) i / b k i) / (b (k+1) j / b k j))|`,
which is at most `Œ≤ k ‚â§ M k`.

This `_core` form carries the minimal hypotheses.  The projective log-oscillation decay depends only
on the orbit, the two Birkhoff contraction coefficients, and `0 ‚â§ Œ≥`.  It needs neither the box
bounds `FranklinLorenzScalingBoxBounds` (which enter later, in the box-ratio lemma) nor `Œ≥ < 1`
(which enters later, in the log-to-error real-analysis conversion).  The
`..._geometric_bound` wrapper retains both for source/context fidelity. -/
theorem hard_core_franklinLorenz_right_column_pairwise_log_correction_geometric_bound_core
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (horbit : IsFiniteFranklinLorenzScalingOrbit p q G a b)
    (Œ≥ : ‚Ñù) (hŒ≥_nonneg : 0 ‚â§ Œ≥)
    (hŒ≥_contract : ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient G Œ≥)
    (hŒ≥_contract_transpose :
      ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient (fun j i => G i j) Œ≥) :
    ‚àÉ C : ‚Ñù,
      0 ‚â§ C ‚àß
        ‚àÄ k (ij : Œπ √ó Œπ),
          |Real.log
            ((q ij.1 / franklinLorenzCurrentColumnMarginal G a b k ij.1) /
              (q ij.2 / franklinLorenzCurrentColumnMarginal G a b k ij.2))| ‚â§ C * Œ≥ ^ k := by
  classical
  rcases isEmpty_or_nonempty Œπ with hŒπ | hŒπ
  ¬∑ haveI : IsEmpty Œπ := hŒπ
    exact ‚ü®0, le_rfl, fun _ ij => (IsEmpty.false ij.1).elim‚ü©
  haveI : Nonempty Œπ := hŒπ
  set d : (Œπ ‚Üí ‚Ñù) ‚Üí (Œπ ‚Üí ‚Ñù) ‚Üí ‚Ñù := ForMathlib.Matrix.finiteHilbertProjectiveLogSpread with hd
  -- the two half-step images
  set S : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù := fun k => ForMathlib.Matrix.positiveKernelApply (fun j i => G i j) (a k)
    with hS
  set T : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù := fun k => ForMathlib.Matrix.positiveKernelApply G (b k) with hT
  have hS_pos : ‚àÄ k j, 0 < S k j := fun k j =>
    ForMathlib.Matrix.positiveKernelApply_pos (fun j' i => G i j') (fun j' i => hG i j')
      (a k) (horbit.left_pos k) j
  have hT_pos : ‚àÄ k i, 0 < T k i := fun k i =>
    ForMathlib.Matrix.positiveKernelApply_pos G hG (b k) (horbit.right_pos k) i
  have hq_pos : ‚àÄ j, 0 < q j := fun j => franklinLorenz_targetColumn_pos p q G a b hG horbit 0 j
  have hp_pos : ‚àÄ i, 0 < p i := by
    intro i
    rw [‚Üê horbit.row_update 0 i]
    exact mul_pos (horbit.left_pos 1 i) (hT_pos 0 i)
  have hS_val : ‚àÄ k j, S k j = ‚àë i, G i j * a k i := fun _ _ => rfl
  have hT_val : ‚àÄ k i, T k i = ‚àë j, G i j * b k j := fun _ _ => rfl
  -- the update equations, as function identities
  have hb_eq : ‚àÄ k, b (k + 1) = fun j => q j / S k j := by
    intro k; funext j
    rw [eq_div_iff (ne_of_gt (hS_pos k j)), hS_val k j]
    exact horbit.column_update k j
  have ha_eq : ‚àÄ k, a (k + 1) = fun i => p i / T k i := by
    intro k; funext i
    rw [eq_div_iff (ne_of_gt (hT_pos k i)), hT_val k i]
    exact horbit.row_update k i
  -- one-step contraction of the two correction spreads
  set Œ± : ‚Ñï ‚Üí ‚Ñù := fun k => d (a (k + 1)) (a k) with hŒ±
  set Œ≤ : ‚Ñï ‚Üí ‚Ñù := fun k => d (b (k + 1)) (b k) with hŒ≤
  have hŒ±_nonneg : ‚àÄ k, 0 ‚â§ Œ± k := fun k =>
    ForMathlib.Matrix.finiteHilbertProjectiveLogSpread_nonneg_of_pos _ _
      (horbit.left_pos (k + 1)) (horbit.left_pos k)
  have hŒ≤_nonneg : ‚àÄ k, 0 ‚â§ Œ≤ k := fun k =>
    ForMathlib.Matrix.finiteHilbertProjectiveLogSpread_nonneg_of_pos _ _
      (horbit.right_pos (k + 1)) (horbit.right_pos k)
  have hŒ≤_step : ‚àÄ k, Œ≤ (k + 1) ‚â§ Œ≥ * Œ± k := by
    intro k
    have hrw : Œ≤ (k + 1) = d (S (k + 1)) (S k) := by
      rw [hŒ≤]
      simp only
      rw [hb_eq (k + 1), hb_eq k]
      exact ForMathlib.Matrix.finiteHilbertProjectiveLogSpread_div_left q (S (k + 1)) (S k)
        hq_pos (hS_pos _) (hS_pos _)
    rw [hrw]
    exact hŒ≥_contract_transpose (a (k + 1)) (a k) (horbit.left_pos (k + 1)) (horbit.left_pos k)
  have hŒ±_step : ‚àÄ k, Œ± (k + 1) ‚â§ Œ≥ * Œ≤ k := by
    intro k
    have hrw : Œ± (k + 1) = d (T (k + 1)) (T k) := by
      rw [hŒ±]
      simp only
      rw [ha_eq (k + 1), ha_eq k]
      exact ForMathlib.Matrix.finiteHilbertProjectiveLogSpread_div_left p (T (k + 1)) (T k)
        hp_pos (hT_pos _) (hT_pos _)
    rw [hrw]
    exact hŒ≥_contract (b (k + 1)) (b k) (horbit.right_pos (k + 1)) (horbit.right_pos k)
  -- the max of the two decays with a single-step recursion
  set M : ‚Ñï ‚Üí ‚Ñù := fun k => max (Œ± k) (Œ≤ k) with hM
  have hM_nonneg : ‚àÄ k, 0 ‚â§ M k := fun k => le_trans (hŒ±_nonneg k) (le_max_left _ _)
  have hM_step : ‚àÄ k, M (k + 1) ‚â§ Œ≥ * M k := by
    intro k
    refine max_le ?_ ?_
    ¬∑ exact le_trans (hŒ±_step k) (mul_le_mul_of_nonneg_left (le_max_right _ _) hŒ≥_nonneg)
    ¬∑ exact le_trans (hŒ≤_step k) (mul_le_mul_of_nonneg_left (le_max_left _ _) hŒ≥_nonneg)
  have hM_geom : ‚àÄ k, M k ‚â§ Œ≥ ^ k * M 0 := by
    intro k
    induction k with
    | zero => simp
    | succ n ih =>
        calc M (n + 1) ‚â§ Œ≥ * M n := hM_step n
          _ ‚â§ Œ≥ * (Œ≥ ^ n * M 0) := mul_le_mul_of_nonneg_left ih hŒ≥_nonneg
          _ = Œ≥ ^ (n + 1) * M 0 := by ring
  refine ‚ü®M 0, hM_nonneg 0, ?_‚ü©
  intro k ij
  -- identify the correction ratio with `b (k+1) / b k`
  have hcorr : ‚àÄ i, q i / franklinLorenzCurrentColumnMarginal G a b k i = b (k + 1) i / b k i := by
    intro i
    unfold franklinLorenzCurrentColumnMarginal
    rw [‚Üê horbit.column_update k i]
    have h1 : (0 : ‚Ñù) < ‚àë i', G i' i * a k i' := hS_pos k i
    have h2 : 0 < b k i := horbit.right_pos k i
    field_simp
  rw [hcorr ij.1, hcorr ij.2]
  have hratio : (b (k + 1) ij.1 / b k ij.1) / (b (k + 1) ij.2 / b k ij.2)
      = (b (k + 1) ij.1 * b k ij.2) / (b (k + 1) ij.2 * b k ij.1) := by
    have h1 := (horbit.right_pos (k + 1) ij.1).ne'
    have h2 := (horbit.right_pos (k + 1) ij.2).ne'
    have h3 := (horbit.right_pos k ij.1).ne'
    have h4 := (horbit.right_pos k ij.2).ne'
    field_simp
  rw [hratio]
  calc |Real.log ((b (k + 1) ij.1 * b k ij.2) / (b (k + 1) ij.2 * b k ij.1))|
      ‚â§ Œ≤ k := ForMathlib.Matrix.finiteHilbertProjectiveLogSpread_abs_pair_le _ _
        (horbit.right_pos (k + 1)) (horbit.right_pos k) ij.1 ij.2
    _ ‚â§ M k := le_max_right _ _
    _ ‚â§ Œ≥ ^ k * M 0 := hM_geom k
    _ = M 0 * Œ≥ ^ k := by ring

/-- Source/context-facing wrapper for
`hard_core_franklinLorenz_right_column_pairwise_log_correction_geometric_bound_core`.

The `_hbox` and `_hŒ≥_lt_one` hypotheses are retained for compatibility and source fidelity, but they
are **not** mathematical premises of this projective log-oscillation decay: the proof lives in the
`_core` lemma.  `FranklinLorenzScalingBoxBounds` and `Œ≥ < 1` are genuinely needed only downstream,
by the box-ratio lemma and the log-to-error conversion respectively. -/
theorem hard_core_franklinLorenz_right_column_pairwise_log_correction_geometric_bound
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (horbit : IsFiniteFranklinLorenzScalingOrbit p q G a b)
    (_hbox : FranklinLorenzScalingBoxBounds a b)
    (Œ≥ : ‚Ñù) (hŒ≥_nonneg : 0 ‚â§ Œ≥) (_hŒ≥_lt_one : Œ≥ < 1)
    (hŒ≥_contract : ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient G Œ≥)
    (hŒ≥_contract_transpose :
      ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient (fun j i => G i j) Œ≥) :
    ‚àÉ C : ‚Ñù,
      0 ‚â§ C ‚àß
        ‚àÄ k (ij : Œπ √ó Œπ),
          |Real.log
            ((q ij.1 / franklinLorenzCurrentColumnMarginal G a b k ij.1) /
              (q ij.2 / franklinLorenzCurrentColumnMarginal G a b k ij.2))| ‚â§ C * Œ≥ ^ k :=
  hard_core_franklinLorenz_right_column_pairwise_log_correction_geometric_bound_core
    p q G a b hG horbit Œ≥ hŒ≥_nonneg hŒ≥_contract hŒ≥_contract_transpose

/-- Uniform finite-box bound for the right-column relative ratio `q / c_k`.

This is a finite-order/box-bounds seam, independent of Hilbert contraction.  From the update equation
`q_j = b_{k+1,j} * ‚àë_i G_ij a_{k,i}`, the quotient `q_j / c_{k,j}` is exactly
`b_{k+1,j} / b_{k,j}`, so the two-sequence box bounds give the uniform bound `B / Œµ`. -/
theorem franklinLorenz_right_column_relative_ratio_box_bound
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (horbit : IsFiniteFranklinLorenzScalingOrbit p q G a b)
    (hbox : FranklinLorenzScalingBoxBounds a b) :
    ‚àÉ R : ‚Ñù,
      0 ‚â§ R ‚àß
        ‚àÄ k j,
          |q j / franklinLorenzCurrentColumnMarginal G a b k j| ‚â§ R := by
  classical
  rcases hbox with ‚ü®Œµ, B, hŒµ, hB, ha_box, hb_box‚ü©
  refine ‚ü®B / Œµ, le_of_lt (div_pos hB hŒµ), ?_‚ü©
  intro k j
  let S : ‚Ñù := ‚àë i, G i j * a k i
  have hS_pos : 0 < S := by
    dsimp [S]
    apply Finset.sum_pos
    ¬∑ intro i _hi
      exact mul_pos (hG i j) (horbit.left_pos k i)
    ¬∑ exact ‚ü®j, Finset.mem_univ j‚ü©
  have hb_k_pos : 0 < b k j := lt_of_lt_of_le hŒµ (hb_box k j).1
  have hb_next_nonneg : 0 ‚â§ b (k + 1) j :=
    le_trans (le_of_lt hŒµ) (hb_box (k + 1) j).1
  have hratio_eq :
      q j / franklinLorenzCurrentColumnMarginal G a b k j = b (k + 1) j / b k j := by
    unfold franklinLorenzCurrentColumnMarginal
    dsimp [S] at hS_pos
    rw [‚Üê horbit.column_update k j]
    field_simp [ne_of_gt hS_pos, ne_of_gt hb_k_pos]
  have hmul : b (k + 1) j * Œµ ‚â§ B * b k j := by
    have h1 : b (k + 1) j * Œµ ‚â§ B * Œµ := by
      exact mul_le_mul_of_nonneg_right (hb_box (k + 1) j).2 (le_of_lt hŒµ)
    have h2 : B * Œµ ‚â§ B * b k j := by
      exact mul_le_mul_of_nonneg_left (hb_box k j).1 (le_of_lt hB)
    exact le_trans h1 h2
  rw [hratio_eq]
  have hratio_nonneg : 0 ‚â§ b (k + 1) j / b k j :=
    div_nonneg hb_next_nonneg (le_of_lt hb_k_pos)
  rw [abs_of_nonneg hratio_nonneg]
  field_simp [ne_of_gt hb_k_pos, ne_of_gt hŒµ]
  simpa [mul_comm, mul_left_comm, mul_assoc] using hmul

/-- Hard core 3: convert projective log-oscillation plus a ratio box into concrete pairwise
oscillation.

For positive ratios `r_i`, `r_j` bounded by `R`, a bound on `|log (r_i / r_j)|` should imply a
bound on `|r_i - r_j|` at the same geometric rate, with a larger constant depending on the box.
This is the faithful replacement for the earlier pointwise log-to-one conversion. -/
theorem hard_core_franklinLorenz_pairwise_correction_bound_of_pairwise_log_bound_and_ratio_box
    {Œπ : Type*} [Fintype Œπ]
    (_p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (Œ≥ : ‚Ñù) (hŒ≥_nonneg : 0 ‚â§ Œ≥) (hŒ≥_lt_one : Œ≥ < 1)
    (hratio_pos : ‚àÄ k j, 0 < q j / franklinLorenzCurrentColumnMarginal G a b k j)
    (hratio_box : ‚àÉ R : ‚Ñù,
      0 ‚â§ R ‚àß ‚àÄ k j, |q j / franklinLorenzCurrentColumnMarginal G a b k j| ‚â§ R)
    (hlog : ‚àÉ C : ‚Ñù,
      0 ‚â§ C ‚àß
        ‚àÄ k (ij : Œπ √ó Œπ),
          |Real.log
            ((q ij.1 / franklinLorenzCurrentColumnMarginal G a b k ij.1) /
              (q ij.2 / franklinLorenzCurrentColumnMarginal G a b k ij.2))| ‚â§ C * Œ≥ ^ k) :
    ‚àÉ C : ‚Ñù,
      0 ‚â§ C ‚àß
        ‚àÄ k (ij : Œπ √ó Œπ),
          |q ij.1 / franklinLorenzCurrentColumnMarginal G a b k ij.1 -
            q ij.2 / franklinLorenzCurrentColumnMarginal G a b k ij.2| ‚â§ C * Œ≥ ^ k := by
  classical
  let r : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù := fun k j => q j / franklinLorenzCurrentColumnMarginal G a b k j
  exact ForMathlib.Analysis.pairwise_error_geometric_bound_of_pairwise_log_ratio_bound_and_box
    r Œ≥ hŒ≥_nonneg hŒ≥_lt_one hratio_pos hratio_box hlog

/-- Pairwise right-column correction oscillation bound for a two-sequence Franklin--Lorenz orbit.

This is now the composition of the faithful Franklin--Lorenz projective-log seam and the finite
real-analysis box conversion.  It no longer relies on the stronger pointwise-to-one log-error
statement. -/
theorem franklinLorenz_right_column_correction_pairwise_geometric_bound_of_birkhoff_coefficient
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (horbit : IsFiniteFranklinLorenzScalingOrbit p q G a b)
    (hbox : FranklinLorenzScalingBoxBounds a b)
    (Œ≥ : ‚Ñù) (hŒ≥_nonneg : 0 ‚â§ Œ≥) (hŒ≥_lt_one : Œ≥ < 1)
    (hŒ≥_contract : ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient G Œ≥)
    (hŒ≥_contract_transpose :
      ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient (fun j i => G i j) Œ≥) :
    ‚àÉ C : ‚Ñù,
      0 ‚â§ C ‚àß
        ‚àÄ k (ij : Œπ √ó Œπ),
          |q ij.1 / franklinLorenzCurrentColumnMarginal G a b k ij.1 -
            q ij.2 / franklinLorenzCurrentColumnMarginal G a b k ij.2| ‚â§ C * Œ≥ ^ k := by
  have hratio_pos :
      ‚àÄ k j, 0 < q j / franklinLorenzCurrentColumnMarginal G a b k j := by
    intro k j
    exact div_pos
      (franklinLorenz_targetColumn_pos p q G a b hG horbit k j)
      (franklinLorenzCurrentColumnMarginal_pos G a b hG horbit.left_pos horbit.right_pos k j)
  exact hard_core_franklinLorenz_pairwise_correction_bound_of_pairwise_log_bound_and_ratio_box
    p q G a b Œ≥ hŒ≥_nonneg hŒ≥_lt_one hratio_pos
    (franklinLorenz_right_column_relative_ratio_box_bound p q G a b hG horbit hbox)
    (hard_core_franklinLorenz_right_column_pairwise_log_correction_geometric_bound_core
      p q G a b hG horbit Œ≥ hŒ≥_nonneg hŒ≥_contract hŒ≥_contract_transpose)

/-- Pure two-sequence Franklin--Lorenz right-column correction geometric bound.

This theorem now performs only the finite-sum bookkeeping: the genuine contraction estimate is the
pairwise theorem
`franklinLorenz_right_column_correction_pairwise_geometric_bound_of_birkhoff_coefficient` above.
It has no four-phase Sinkhorn bookkeeping. -/
theorem franklinLorenz_right_column_correction_spread_geometric_bound_of_birkhoff_coefficient
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (horbit : IsFiniteFranklinLorenzScalingOrbit p q G a b)
    (hbox : FranklinLorenzScalingBoxBounds a b)
    (Œ≥ : ‚Ñù) (hŒ≥_nonneg : 0 ‚â§ Œ≥) (hŒ≥_lt_one : Œ≥ < 1)
    (hŒ≥_contract : ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient G Œ≥)
    (hŒ≥_contract_transpose :
      ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient (fun j i => G i j) Œ≥) :
    ‚àÉ C : ‚Ñù,
      0 ‚â§ C ‚àß
        ‚àÄ k, ForMathlib.Matrix.finitePairwiseRatioSpread q
            (franklinLorenzCurrentColumnMarginal G a b k) ‚â§ C * Œ≥ ^ k := by
  obtain ‚ü®C, hC_nonneg, hpair‚ü© :=
    franklinLorenz_right_column_correction_pairwise_geometric_bound_of_birkhoff_coefficient
      p q G a b hG horbit hbox Œ≥ hŒ≥_nonneg hŒ≥_lt_one hŒ≥_contract hŒ≥_contract_transpose
  refine ‚ü®(Fintype.card (Œπ √ó Œπ) : ‚Ñù) * C,
    mul_nonneg (Nat.cast_nonneg _) hC_nonneg, ?_‚ü©
  intro k
  unfold ForMathlib.Matrix.finitePairwiseRatioSpread
  calc
    (‚àë ij : Œπ √ó Œπ,
        |q ij.1 / franklinLorenzCurrentColumnMarginal G a b k ij.1 -
          q ij.2 / franklinLorenzCurrentColumnMarginal G a b k ij.2|)
        ‚â§ ‚àë _ij : Œπ √ó Œπ, C * Œ≥ ^ k := by
          exact Finset.sum_le_sum (fun ij _hij => hpair k ij)
    _ = (Fintype.card (Œπ √ó Œπ) : ‚Ñù) * (C * Œ≥ ^ k) := by
          simp
    _ = ((Fintype.card (Œπ √ó Œπ) : ‚Ñù) * C) * Œ≥ ^ k := by
          ring

/-- Algebraic identification of the right forward correction spread with the spread of the column
marginal correction `q / currentColumnMarginal`.

This is a small but important orientation/phase-index lemma for the right-side port.  It should be
proved directly from `hiter.normalize_right k j`, positivity of `œÜ1Iter k j` and
`œÜhat1Iter k j`, and the definition of `finitePairwiseRatioSpread`. -/
theorem sinkhorn_phi1_forward_ratio_spread_eq_column_marginal_correction_spread
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hiter : IsFiniteSinkhornIterateSystem p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter)
    (k : ‚Ñï) :
    finiteForwardRatioSpread œÜ1Iter k =
      ForMathlib.Matrix.finitePairwiseRatioSpread q
        (sinkhornCurrentColumnMarginal œÜ1Iter œÜhat1Iter k) := by
  classical
  unfold finiteForwardRatioSpread ForMathlib.Matrix.finitePairwiseRatioSpread
    sinkhornCurrentColumnMarginal
  apply Finset.sum_congr rfl
  intro ij _hij
  have hi_ratio :
      œÜ1Iter (k + 1) ij.1 / œÜ1Iter k ij.1 =
        q ij.1 / (œÜhat1Iter k ij.1 * œÜ1Iter k ij.1) := by
    have hœÜ1_ne : œÜ1Iter k ij.1 ‚âÝ 0 := ne_of_gt (hiter.œÜ1_pos k ij.1)
    have hœÜhat1_ne : œÜhat1Iter k ij.1 ‚âÝ 0 := ne_of_gt (hiter.œÜhat1_pos k ij.1)
    have hprod_ne : œÜhat1Iter k ij.1 * œÜ1Iter k ij.1 ‚âÝ 0 :=
      mul_ne_zero hœÜhat1_ne hœÜ1_ne
    have hnorm := hiter.normalize_right k ij.1
    field_simp [hœÜ1_ne, hprod_ne]
    nlinarith [hnorm]
  have hj_ratio :
      œÜ1Iter (k + 1) ij.2 / œÜ1Iter k ij.2 =
        q ij.2 / (œÜhat1Iter k ij.2 * œÜ1Iter k ij.2) := by
    have hœÜ1_ne : œÜ1Iter k ij.2 ‚âÝ 0 := ne_of_gt (hiter.œÜ1_pos k ij.2)
    have hœÜhat1_ne : œÜhat1Iter k ij.2 ‚âÝ 0 := ne_of_gt (hiter.œÜhat1_pos k ij.2)
    have hprod_ne : œÜhat1Iter k ij.2 * œÜ1Iter k ij.2 ‚âÝ 0 :=
      mul_ne_zero hœÜhat1_ne hœÜ1_ne
    have hnorm := hiter.normalize_right k ij.2
    field_simp [hœÜ1_ne, hprod_ne]
    nlinarith [hnorm]
  rw [hi_ratio, hj_ratio]

/-- Right-side Franklin--Lorenz contraction target for the current column marginal correction.

This is now the real hard column-normalization port.  Starting from a strict Hilbert-projective
contraction coefficient `Œ≥` for the positive kernel, Franklin--Lorenz Section 3 should give a finite
constant `C` such that the finite spread of the column correction `q / currentColumnMarginal` decays
geometrically.

Suggested proof route:
1. use `sinkhorn_rowNormalizedMatrix_column_sum` to identify
   `sinkhornCurrentColumnMarginal œÜ1Iter œÜhat1Iter k` with the column sums of the row-normalized
   matrix at step `k - 1` / the pre-column-normalization marginal error;
2. use the Birkhoff--Hopf contraction coefficient `Œ≥` for the positive kernel to get the
   Franklin--Lorenz Lemma 2/Theorem 4 geometric estimate for those marginal-error corrections;
3. use `SinkhornPhaseBoxBounds` to translate Hilbert/projective correction control into the concrete
   finite quotient spread below. -/
theorem sinkhorn_phi1_column_marginal_correction_spread_geometric_bound_of_birkhoff_coefficient
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0 œÜhat0 œÜ1 œÜhat1 : Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (hiter : IsFiniteSinkhornIterateSystem p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter)
    (_hgauge : IsFiniteSinkhornGaugeNormalized œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter
      œÜ0 œÜhat0 œÜ1 œÜhat1)
    (hbounds : SinkhornPhaseBoxBounds œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter)
    (Œ≥ : ‚Ñù) (hŒ≥_nonneg : 0 ‚â§ Œ≥) (hŒ≥_lt_one : Œ≥ < 1)
    (hŒ≥_contract : ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient G Œ≥)
    (hŒ≥_contract_transpose :
      ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient (fun j i => G i j) Œ≥) :
    ‚àÉ C : ‚Ñù,
      0 ‚â§ C ‚àß
        ‚àÄ k, ForMathlib.Matrix.finitePairwiseRatioSpread q
            (sinkhornCurrentColumnMarginal œÜ1Iter œÜhat1Iter k) ‚â§ C * Œ≥ ^ k := by
  obtain ‚ü®C, hC_nonneg, hbound‚ü© :=
    franklinLorenz_right_column_correction_spread_geometric_bound_of_birkhoff_coefficient
      p q G œÜhat0Iter œÜ1Iter hG
      (sinkhorn_isFiniteFranklinLorenzScalingOrbit p q G
        œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter hiter)
      (franklinLorenzScalingBoxBounds_of_sinkhornPhaseBoxBounds
        œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter hbounds)
      Œ≥ hŒ≥_nonneg hŒ≥_lt_one hŒ≥_contract hŒ≥_contract_transpose
  refine ‚ü®C, hC_nonneg, ?_‚ü©
  intro k
  rw [sinkhorn_currentColumnMarginal_eq_franklinLorenzCurrentColumnMarginal
    p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter hiter k]
  exact hbound k

/-- Right-side Franklin--Lorenz core under a chosen Birkhoff contraction coefficient.

The original right-side geometric-bound theorem is now just the composition of two smaller
right-side obligations: the phase algebra identifying the forward correction as `q / currentColumn`
and the Franklin--Lorenz geometric bound for that current-column correction spread. -/
theorem sinkhorn_phi1_forward_ratio_spread_geometric_bound_of_birkhoff_coefficient
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0 œÜhat0 œÜ1 œÜhat1 : Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (hiter : IsFiniteSinkhornIterateSystem p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter)
    (hgauge : IsFiniteSinkhornGaugeNormalized œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter
      œÜ0 œÜhat0 œÜ1 œÜhat1)
    (hbounds : SinkhornPhaseBoxBounds œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter)
    (Œ≥ : ‚Ñù) (hŒ≥_nonneg : 0 ‚â§ Œ≥) (hŒ≥_lt_one : Œ≥ < 1)
    (hŒ≥_contract : ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient G Œ≥)
    (hŒ≥_contract_transpose :
      ForMathlib.Matrix.IsBirkhoffHopfContractionCoefficient (fun j i => G i j) Œ≥) :
    ‚àÉ C : ‚Ñù,
      0 ‚â§ C ‚àß ‚àÄ k, finiteForwardRatioSpread œÜ1Iter k ‚â§ C * Œ≥ ^ k := by
  obtain ‚ü®C, hC_nonneg, hbound‚ü© :=
    sinkhorn_phi1_column_marginal_correction_spread_geometric_bound_of_birkhoff_coefficient
      p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter œÜ0 œÜhat0 œÜ1 œÜhat1
      hG hiter hgauge hbounds Œ≥ hŒ≥_nonneg hŒ≥_lt_one hŒ≥_contract hŒ≥_contract_transpose
  refine ‚ü®C, hC_nonneg, ?_‚ü©
  intro k
  rw [sinkhorn_phi1_forward_ratio_spread_eq_column_marginal_correction_spread
    p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter hiter k]
  exact hbound k

/-- The transposed Franklin--Lorenz orbit.

`IsFiniteFranklinLorenzScalingOrbit` is symmetric under `(p, q, G, a, b) ‚Ü¶ (q, p, G·µÄ, b, a)`: the
row and column update equations swap into each other.  This is what makes the left-side
row-correction theorem an instantiation of the right-side column-correction theorem rather than a
second proof. -/
theorem isFiniteFranklinLorenzScalingOrbit_transpose {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù) (a b : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (horbit : IsFiniteFranklinLorenzScalingOrbit p q G a b) :
    IsFiniteFranklinLorenzScalingOrbit q p (fun j i => G i j) b a :=
  ‚ü®horbit.right_pos, horbit.left_pos, horbit.column_update, horbit.row_update‚ü©

/-- The Sinkhorn four-phase iterate system induces the *transposed* two-sequence orbit
`(œÜ1Iter, œÜhat0Iter)` for `(q, p, G·µÄ)`. -/
theorem sinkhorn_isFiniteFranklinLorenzScalingOrbit_transpose {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hiter : IsFiniteSinkhornIterateSystem p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter) :
    IsFiniteFranklinLorenzScalingOrbit q p (fun j i => G i j) œÜ1Iter œÜhat0Iter :=
  isFiniteFranklinLorenzScalingOrbit_transpose p q G œÜhat0Iter œÜ1Iter
    (sinkhorn_isFiniteFranklinLorenzScalingOrbit p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter hiter)

/-- The four-phase Sinkhorn box bounds imply the transposed two-sequence box bounds. -/
theorem franklinLorenzScalingBoxBounds_of_sinkhornPhaseBoxBounds_transpose {Œπ : Type*}
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hbounds : SinkhornPhaseBoxBounds œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter) :
    FranklinLorenzScalingBoxBounds œÜ1Iter œÜhat0Iter := by
  rcases hbounds with ‚ü®Œµ, B, hŒµ, hB, _hœÜ0, hœÜhat0, hœÜ1, _hœÜhat1‚ü©
  exact ‚ü®Œµ, B, hŒµ, hB, hœÜ1, hœÜhat0‚ü©

/-- Row analogue of `sinkhorn_phi1_forward_ratio_spread_eq_column_marginal_correction_spread`.

The left forward correction `œÜhat0Iter (k+1) / œÜhat0Iter k` is `p / r_k`, where `r_k` is the current
*row* marginal ‚Äî which is exactly the current *column* marginal of the transposed orbit. -/
theorem sinkhorn_phihat0_forward_ratio_spread_eq_row_marginal_correction_spread
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (hiter : IsFiniteSinkhornIterateSystem p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter)
    (k : ‚Ñï) :
    finiteForwardRatioSpread œÜhat0Iter k =
      ForMathlib.Matrix.finitePairwiseRatioSpread p
        (franklinLorenzCurrentColumnMarginal (fun j i => G i j) œÜ1Iter œÜhat0Iter k) := by
  classical
  have hratio : ‚àÄ i, œÜhat0Iter (k + 1) i / œÜhat0Iter k i
      = p i / (œÜ0Iter k i * œÜhat0Iter k i) := by
    intro i
    have hœÜ0_ne : œÜ0Iter k i ‚âÝ 0 := ne_of_gt (hiter.œÜ0_pos k i)
    have hœÜhat0_ne : œÜhat0Iter k i ‚âÝ 0 := ne_of_gt (hiter.œÜhat0_pos k i)
    have hprod_ne : œÜ0Iter k i * œÜhat0Iter k i ‚âÝ 0 := mul_ne_zero hœÜ0_ne hœÜhat0_ne
    have hnorm := hiter.normalize_left k i
    field_simp [hœÜhat0_ne, hprod_ne]
    nlinarith [hnorm]
  unfold finiteForwardRatioSpread ForMathlib.Matrix.finitePairwiseRatioSpread
    franklinLorenzCurrentColumnMarginal
  apply Finset.sum_congr rfl
  intro ij _hij
  rw [hratio ij.1, hratio ij.2, hiter.forward k ij.1, hiter.forward k ij.2]

/-- Hard core 4: left-side Franklin--Lorenz row-correction geometric bound.

This is the row-normalization analogue of the right-side `œÜ1` development, and it is an
*instantiation* of it rather than a second proof: apply the right-side column theorem to the
transposed orbit `(q, p, G·µÄ, œÜ1Iter, œÜhat0Iter)`.  Note the transpose of `G·µÄ` is `G`, so the two
contraction hypotheses simply swap. -/
theorem hard_core_sinkhorn_phihat0_forward_ratio_spread_geometric_bound
    {Œπ : Type*} [Fintype Œπ]
    (p q : Œπ ‚Üí ‚Ñù) (G : Œπ ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter : ‚Ñï ‚Üí Œπ ‚Üí ‚Ñù)
    (œÜ0 œÜhat0 œÜ1 œÜhat1 : Œπ ‚Üí ‚Ñù)
    (hG : ‚àÄ i j, 0 < G i j)
    (hiter : IsFiniteSinkhornIterateSystem p q G œÜ0Iter œÜhat0Iter œÜ1Iter œÜhat1Iter)
